---
export interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;

const links = [
  { label: 'Solutions',    href: '/',            key: 'solutions' },
  { label: 'Products',     href: '/products',    key: 'products' },
  { label: 'Maintenance',  href: '/maintenance', key: 'maintenance' },
  { label: 'Technology',   href: '#',            key: 'technology' },
  { label: 'About',        href: '#',            key: 'about' },
  { label: 'Contact',      href: '#',            key: 'contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-xl shadow-sm border-b border-slate-200/50 dark:border-slate-800/50">
  <div class="flex justify-between items-center max-w-screen-2xl mx-auto px-6 py-4">
    <a href="/" class="text-xl font-black tracking-tighter text-blue-900 dark:text-blue-100 uppercase">
      AeroPress Industrial
    </a>
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class={
            activeNav === link.key
              ? 'text-blue-700 dark:text-blue-400 border-b-2 border-blue-900 dark:border-blue-400 pb-1 font-sans tracking-tight font-bold uppercase text-xs'
              : 'text-slate-600 dark:text-slate-400 hover:text-blue-900 dark:hover:text-blue-100 transition-colors font-sans tracking-tight font-bold uppercase text-xs'
          }
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <button class="steel-gradient text-on-primary px-6 py-2.5 rounded-lg font-bold text-sm uppercase tracking-wider hover:opacity-90 transition-all active:scale-[0.98]">
        Request Quote
      </button>
    </div>
  </div>
</nav>
