---
export interface Props {
  title: string;
  activeNav?: 'solutions' | 'products' | 'maintenance' | 'technology' | 'about' | 'contact';
}

const { title, activeNav } = Astro.props;
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "surface-container-high": "#dde9ff",
              "on-primary": "#ffffff",
              "surface-container-highest": "#d5e3fd",
              "surface-container-lowest": "#ffffff",
              "error-container": "#ffdad6",
              "primary": "#00346f",
              "background": "#f8f9ff",
              "on-primary-fixed": "#001b3f",
              "surface-variant": "#d5e3fd",
              "surface-dim": "#ccdbf4",
              "inverse-on-surface": "#ebf1ff",
              "on-tertiary": "#ffffff",
              "secondary-fixed-dim": "#b7c8e1",
              "inverse-primary": "#abc7ff",
              "secondary": "#505f76",
              "primary-container": "#004a99",
              "error": "#ba1a1a",
              "surface-container": "#e6eeff",
              "on-error": "#ffffff",
              "on-surface": "#0d1c2f",
              "on-tertiary-container": "#ffa87a",
              "on-surface-variant": "#424751",
              "on-error-container": "#93000a",
              "tertiary-fixed": "#ffdbca",
              "surface": "#f8f9ff",
              "on-primary-container": "#9bbdff",
              "on-primary-fixed-variant": "#00458f",
              "outline-variant": "#c2c6d3",
              "inverse-surface": "#233144",
              "tertiary": "#5d2500",
              "on-tertiary-fixed-variant": "#783200",
              "surface-tint": "#255dad",
              "on-tertiary-fixed": "#341100",
              "on-background": "#0d1c2f",
              "tertiary-container": "#803600",
              "primary-fixed": "#d7e2ff",
              "secondary-fixed": "#d3e4fe",
              "on-secondary": "#ffffff",
              "surface-bright": "#f8f9ff",
              "surface-container-low": "#eff4ff",
              "primary-fixed-dim": "#abc7ff",
              "on-secondary-fixed-variant": "#38485d",
              "secondary-container": "#d0e1fb",
              "on-secondary-container": "#54647a",
              "on-secondary-fixed": "#0b1c30",
              "outline": "#737783",
              "tertiary-fixed-dim": "#ffb690",
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem",
            },
            fontFamily: {
              headline: ["Inter"],
              body: ["Inter"],
              label: ["Inter"],
            },
          },
        },
      };
    </script>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .steel-gradient {
        background: linear-gradient(135deg, #00346f 0%, #004a99 100%);
      }
      .kinetic-shadow {
        box-shadow: 0 16px 32px 0 rgba(0, 52, 111, 0.06);
      }
      .glass-panel {
        background: rgba(248, 249, 255, 0.8);
        backdrop-filter: blur(24px);
      }
    </style>
  </head>
  <body class="bg-background text-on-background font-body selection:bg-primary-container selection:text-on-primary-container">
    <slot />
  </body>
</html>
